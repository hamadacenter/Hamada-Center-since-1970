/* CART */
var cart=[];
function addToCart(pid,vi){
  var p=products.find(function(x){return x.id===pid;});
  if(!p||p.soldOut)return;
  var ex=cart.find(function(i){return i.productId===pid&&i.variantIndex===vi;});
  if(ex){ex.qty++;}else{cart.push({productId:pid,variantIndex:vi,qty:1});}
  updateCartCount();renderCart();
  var btn=document.getElementById('add-'+pid);
  if(btn){btn.textContent=t('added');btn.classList.add('added');setTimeout(function(){btn.innerHTML='&#128722; '+t('addToCart');btn.classList.remove('added');},1400);}
}
function updateCartCount(){document.getElementById('cartCount').textContent=cart.reduce(function(s,i){return s+i.qty;},0);}
function changeQty(pid,vi,d){
  var item=cart.find(function(i){return i.productId===pid&&i.variantIndex===vi;});if(!item)return;
  item.qty+=d;
  if(item.qty<=0)cart=cart.filter(function(i){return!(i.productId===pid&&i.variantIndex===vi);});
  updateCartCount();renderCart();
}
function removeFromCart(pid,vi){cart=cart.filter(function(i){return!(i.productId===pid&&i.variantIndex===vi);});updateCartCount();renderCart();}
function cartTotal(){return cart.reduce(function(s,i){var p=products.find(function(x){return x.id===i.productId;});return s+(p?p.variants[i.variantIndex].price*i.qty:0);},0);}
function renderCart(){
  var el=document.getElementById('cartItems');
  if(cart.length===0){el.innerHTML='<div class="cart-empty-msg">'+t('cartEmpty')+' &#128717;</div>';document.getElementById('cartTotal').textContent='0 '+t('currency');return;}
  var h='';
  cart.forEach(function(item){
    var p=products.find(function(x){return x.id===item.productId;});if(!p)return;
    var v=p.variants[item.variantIndex];
    var img=p.images&&p.images.length>0?p.images[0]:(p.img||PLACEHOLDER);
    h+='<div class="cart-item">' +
      '<img src="'+img+'" alt="'+esc(p.name)+'" onerror="this.src=PLACEHOLDER">' +
      '<div class="ci-info"><div class="ci-name">'+esc(p.name)+'</div><div class="ci-variant">'+esc(v.label)+'</div><div class="ci-price">'+(v.price*item.qty)+' '+t('currency')+'</div>' +
      '<div class="ci-qty"><button class="qty-btn" onclick="changeQty(\''+p.id+'\','+item.variantIndex+',-1)">-</button><span class="qty-num">'+item.qty+'</span><button class="qty-btn" onclick="changeQty(\''+p.id+'\','+item.variantIndex+',1)">+</button>' +
      '<button class="remove-item" onclick="removeFromCart(\''+p.id+'\','+item.variantIndex+')">&#128465; '+t('removeItem')+'</button></div></div></div>';
  });
  el.innerHTML=h;
  document.getElementById('cartTotal').textContent=cartTotal()+' '+t('currency');
}
function openCart(){document.getElementById('cartOverlay').classList.add('open');document.getElementById('cartSidebar').classList.add('open');}
function closeCart(){document.getElementById('cartOverlay').classList.remove('open');document.getElementById('cartSidebar').classList.remove('open');}

/* ORDER */
function openOrderModal(){if(cart.length===0)return;closeCart();buildSummary();document.getElementById('orderModal').classList.add('open');}
function closeOrderModal(){document.getElementById('orderModal').classList.remove('open');resetForm();rebuildModal();}
function buildSummary(){
  var h='';
  cart.forEach(function(item){var p=products.find(function(x){return x.id===item.productId;});if(!p)return;var v=p.variants[item.variantIndex];h+='<div class="os-item"><span>'+esc(p.name)+' ('+esc(v.label)+') x'+item.qty+'</span><span>'+(v.price*item.qty)+' '+t('currency')+'</span></div>';});
  h+='<div class="os-total"><span>'+t('totalLabel')+'</span><span>'+cartTotal()+' '+t('currency')+'</span></div>';
  document.getElementById('orderSummary').innerHTML=h;
}
function resetForm(){['fieldAddress','fieldCity','fieldPhone'].forEach(function(id){var e=document.getElementById(id);if(e){e.value='';e.classList.remove('err');}});['errAddress','errCity','errPhone'].forEach(function(id){var e=document.getElementById(id);if(e)e.classList.remove('show');});}
function rebuildModal(){
  var m=document.getElementById('modalContent');
  if(!m.querySelector('.success-screen'))return;
  m.innerHTML='<h2 id="modalTitle">'+t('modalTitle')+'</h2><p class="subtitle" id="modalSub">'+t('modalSub')+'</p><div class="order-summary" id="orderSummary"></div>'+
    '<div class="field-group"><label id="labelAddress">'+t('labelAddress')+'</label><input type="text" id="fieldAddress" placeholder="'+t('phAddress')+'"><div class="err-msg" id="errAddress">'+t('errAddress')+'</div></div>'+
    '<div class="field-group"><label id="labelCity">'+t('labelCity')+'</label><input type="text" id="fieldCity" placeholder="'+t('phCity')+'"><div class="err-msg" id="errCity">'+t('errCity')+'</div></div>'+
    '<div class="field-group"><label id="labelPhone">'+t('labelPhone')+'</label><input type="tel" id="fieldPhone" placeholder="'+t('phPhone')+'"><div class="err-msg" id="errPhone">'+t('errPhone')+'</div></div>'+
    '<div class="modal-actions"><button class="btn-cancel" onclick="closeOrderModal()" id="btnCancel">'+t('btnCancel')+'</button><button class="btn-submit" onclick="submitOrder()" id="btnSubmit">'+t('btnSubmit')+'</button></div>';
}
function validate(){
  var ok=true;
  var addr=document.getElementById('fieldAddress').value.trim();
  var city=document.getElementById('fieldCity').value.trim();
  var phone=document.getElementById('fieldPhone').value.trim();
  function chk(val,fid,eid){if(!val){document.getElementById(fid).classList.add('err');document.getElementById(eid).classList.add('show');ok=false;}else{document.getElementById(fid).classList.remove('err');document.getElementById(eid).classList.remove('show');}}
  chk(addr,'fieldAddress','errAddress');chk(city,'fieldCity','errCity');
  if(!/^[0-9+\s]{7,15}$/.test(phone)){document.getElementById('fieldPhone').classList.add('err');document.getElementById('errPhone').classList.add('show');ok=false;}
  else{document.getElementById('fieldPhone').classList.remove('err');document.getElementById('errPhone').classList.remove('show');}
  return ok?{addr:addr,city:city,phone:phone}:null;
}
function submitOrder(){
  var vals=validate();if(!vals)return;
  var btn=document.getElementById('btnSubmit');btn.disabled=true;btn.textContent='...';
  var items=cart.map(function(item){var p=products.find(function(x){return x.id===item.productId;});var v=p.variants[item.variantIndex];return{name:p.name,variant:v.label,qty:item.qty,price:v.price*item.qty};});
  var total=cartTotal();
  var lines=items.map(function(i){return '&#8226; '+i.name+' ('+i.variant+') x'+i.qty+' = '+i.price+' '+t('currency');}).join('\n');
  var msg='&#128717; &#1591;&#1604;&#1576; &#1580;&#1583;&#1610;&#1583; &#1605;&#1606; &#1605;&#1608;&#1602;&#1593; &#1581;&#1605;&#1575;&#1583;&#1577; &#1587;&#1606;&#1578;&#1585;\n========================\n'+lines+'\n========================\n&#128176; &#1575;&#1604;&#1573;&#1580;&#1605;&#1575;&#1604;&#1610;: '+total+' '+t('currency')+'\n========================\n&#128205; &#1575;&#1604;&#1593;&#1606;&#1608;&#1575;&#1606;: '+vals.addr+'\n&#127961; &#1575;&#1604;&#1605;&#1583;&#1610;&#1606;&#1577;: '+vals.city+'\n&#128222; &#1607;&#1575;&#1578;&#1601; &#1575;&#1604;&#1593;&#1605;&#1610;&#1604;: '+vals.phone;
  var waUrl='https://wa.me/201095951764?text='+encodeURIComponent(msg);
  var w=window.open(waUrl,'_blank');
  if(!w||w.closed||typeof w.closed==='undefined')window.location.href=waUrl;
  sb.from('orders').insert([{items:items,total:total,address:vals.addr,city:vals.city,customer_phone:vals.phone,status:'&#1580;&#1583;&#1610;&#1583;',created_at:new Date().toISOString()}]).then(function(r){if(r.error)console.warn(r.error);});
  showSuccess();
}
function showSuccess(){
  var d=document.createElement('div');d.className='success-screen';
  var ic=document.createElement('div');ic.className='icon';ic.textContent='&#127881;';
  var h3=document.createElement('h3');h3.textContent=t('successTitle');
  var p=document.createElement('p');p.textContent=t('successMsg');
  var wr=document.createElement('div');wr.style.marginTop='22px';
  var cb=document.createElement('button');cb.className='checkout-btn';cb.style.cssText='padding:13px;border-radius:13px;font-size:.95rem;';
  cb.textContent=t('btnClose');cb.onclick=function(){closeOrderModal();cart=[];updateCartCount();renderCart();};
  wr.appendChild(cb);d.appendChild(ic);d.appendChild(h3);d.appendChild(p);d.appendChild(wr);
  var m=document.getElementById('modalContent');m.innerHTML='';m.appendChild(d);
}

/* FEEDBACK */
var fbRating=0;
function openFeedback(){
  fbRating=0;renderStars(0);
  var fn=document.getElementById('fbName');if(fn)fn.value='';
  var fm=document.getElementById('fbMessage');if(fm)fm.value='';
  document.getElementById('fbOverlay').classList.add('open');
}
function closeFeedback(){document.getElementById('fbOverlay').classList.remove('open');}
function setStar(n){fbRating=n;renderStars(n);}
function renderStars(n){var s=document.querySelectorAll('.star');for(var i=0;i<s.length;i++){s[i].classList.toggle('lit',i<n);}}
function sendFeedback(){
  var name=(document.getElementById('fbName').value.trim())||(lang==='ar'?'&#1586;&#1575;&#1574;&#1585;':'Visitor');
  var msg=document.getElementById('fbMessage').value.trim();
  if(!msg){document.getElementById('fbMessage').style.borderColor='#EF4444';return;}
  document.getElementById('fbMessage').style.borderColor='';
  var btn=document.getElementById('fbSendBtn');btn.disabled=true;btn.textContent='...';
  var stars='';for(var i=0;i<fbRating;i++)stars+='&#9733;';for(var j=fbRating;j<5;j++)stars+='&#9734;';
  emailjs.send('service_6w8f269','template_1uk3o9q',{
    title:lang==='ar'?'&#1578;&#1602;&#1610;&#1610;&#1605; &#1605;&#1606; &#1605;&#1608;&#1602;&#1593; &#1581;&#1605;&#1575;&#1583;&#1577; &#1587;&#1606;&#1578;&#1585;':'Feedback - Hamada Center',
    name:name,
    message:(fbRating>0?'&#1575;&#1604;&#1578;&#1602;&#1610;&#1610;&#1605;: '+stars+' ('+fbRating+'/5)\n\n':'')+msg,
    email:'danyfares455@gmail.com'
  }).then(function(){
    var m=document.getElementById('fbModal');m.innerHTML='';
    var wr=document.createElement('div');wr.className='fb-success';
    var ic=document.createElement('div');ic.className='fb-sicon';ic.textContent='&#127881;';
    var h3=document.createElement('h3');h3.textContent=lang==='ar'?'&#1588;&#1603;&#1585;&#1611;&#1575; &#1593;&#1604;&#1609; &#1585;&#1571;&#1610;&#1603;!':'Thank you!';
    var p=document.createElement('p');p.textContent=lang==='ar'?'&#1585;&#1571;&#1610;&#1603; &#1608;&#1589;&#1604; &#1604;&#1606;&#1575;.':'We received your feedback.';
    var cb=document.createElement('button');cb.className='checkout-btn';cb.style.cssText='margin-top:20px;padding:12px;border-radius:12px;font-size:.92rem;';
    cb.textContent=lang==='ar'?'&#1573;&#1594;&#1604;&#1575;&#1602;':'Close';cb.onclick=closeFeedback;
    wr.appendChild(ic);wr.appendChild(h3);wr.appendChild(p);wr.appendChild(cb);m.appendChild(wr);
  },function(err){console.error(err);btn.disabled=false;btn.textContent='&#128232; '+(lang==='ar'?'&#1573;&#1585;&#1587;&#1575;&#1604;':'Send');});
}

/* SUPABASE */
if(typeof SUPABASE_URL==='undefined'||typeof SUPABASE_ANON_KEY==='undefined'){document.getElementById('products').innerHTML='<div class="empty"><h3>&#1582;&#1591;&#1571; &#1601;&#1610; &#1575;&#1604;&#1573;&#1593;&#1583;&#1575;&#1583;</h3></div>';throw new Error('Missing config.js');}
var sb=window.supabase.createClient(SUPABASE_URL,SUPABASE_ANON_KEY);
var products=[];
var activeCategory='&#1575;&#1604;&#1603;&#1604;';
var CATEGORIES_AR=['&#1575;&#1604;&#1603;&#1604;','&#1585;&#1608;&#1580;','&#1601;&#1575;&#1608;&#1606;&#1583;&#1610;&#1588;&#1606;','&#1576;&#1575;&#1604;&#1610;&#1578;','&#1603;&#1608;&#1606;&#1578;&#1608;&#1585;','&#1607;&#1575;&#1610;&#1604;&#1575;&#1610;&#1578;&#1585;','&#1576;&#1608;&#1583;&#1585;&#1577;','&#1605;&#1587;&#1603;&#1585;&#1575;','&#1575;&#1610;&#1604;&#1575;&#1610;&#1606;&#1585;','&#1573;&#1610;&#1588;&#1575;&#1583;&#1608;','&#1587;&#1610;&#1585;&#1608;&#1605;','&#1605;&#1585;&#1591;&#1576; &#1608;&#1580;&#1607;','&#1594;&#1587;&#1608;&#1604;','&#1608;&#1575;&#1602;&#1610; &#1588;&#1605;&#1587;','&#1593;&#1591;&#1608;&#1585;','&#1588;&#1575;&#1605;&#1576;&#1608;','&#1576;&#1604;&#1587;&#1605;','&#1605;&#1575;&#1587;&#1603; &#1588;&#1593;&#1585;','&#1586;&#1610;&#1578; &#1588;&#1593;&#1585;','&#1603;&#1585;&#1610;&#1605; &#1588;&#1593;&#1585;','&#1605;&#1603;&#1608;&#1575;&#1577;','&#1587;&#1588;&#1608;&#1575;&#1585;','&#1571;&#1580;&#1607;&#1586;&#1577;','&#1593;&#1606;&#1575;&#1610;&#1577; &#1576;&#1575;&#1604;&#1580;&#1587;&#1605;','&#1573;&#1603;&#1587;&#1587;&#1608;&#1575;&#1585;&#1575;&#1578;'];
var CATEGORIES_EN=['All','Lipstick','Foundation','Palette','Contour','Highlighter','Powder','Mascara','Eyeliner','Eyeshadow','Serum','Moisturizer','Face Wash','Sunscreen','Perfumes','Shampoo','Conditioner','Hair Mask','Hair Oil','Hair Cream','Hair Iron','Hair Dryer','Devices','Body Care','Accessories'];
function getCatLabel(c){if(lang==='ar')return c;var i=CATEGORIES_AR.indexOf(c);return i>=0?CATEGORIES_EN[i]:c;}
function esc(s){var d=document.createElement('div');d.textContent=s||'';return d.innerHTML;}
var cardPos={};

function loadProducts(){
  sb.from('products').select('*').order('created_at',{ascending:false}).then(function(res){
    if(res.error){document.getElementById('connError').style.display='block';document.getElementById('products').innerHTML='<div class="empty"><h3>'+t('noProducts')+'</h3><p>'+t('noProductsSub')+'</p></div>';return;}
    document.getElementById('connError').style.display='none';
    products=(res.data||[]).map(function(p){
      var imgs=[];
      if(Array.isArray(p.images)&&p.images.length>0){imgs=p.images;}
      else if(p.image){imgs=[p.image];}
      return{id:p.id,name:p.name,category:p.category,desc:p.description||'',img:imgs[0]||'',images:imgs,variants:Array.isArray(p.variants)?p.variants:[],isNew:!!p.is_new,soldOut:!!p.sold_out};
    }).filter(function(p){return p.variants.length>0;});
    activeCategory='&#1575;&#1604;&#1603;&#1604;';
    renderFilters();renderProducts();renderDrawer();
  }).catch(function(){document.getElementById('connError').style.display='block';});
}

function renderFilters(){
  var ac={};products.forEach(function(p){ac[p.category]=true;});
  var h='';
  CATEGORIES_AR.forEach(function(c){
    var has=c==='&#1575;&#1604;&#1603;&#1604;'||ac[c];if(!has)return;
    var isA=c===activeCategory;
    h+='<button class="filter-btn'+(isA?' active':'')+'" onclick="setCategory(\''+c.replace(/'/g,"\\'")+'\')">'+getCatLabel(c)+'</button>';
  });
  document.getElementById('filters').innerHTML=h;
}

function setCategory(cat){
  activeCategory=cat;renderFilters();renderProducts();renderDrawer();
  var sh=document.getElementById('sectionHeading');
  if(sh)sh.innerHTML=cat==='&#1575;&#1604;&#1603;&#1604;'?(lang==='ar'?'&#1580;&#1605;&#1610;&#1593; <em>&#1575;&#1604;&#1605;&#1606;&#1578;&#1580;&#1575;&#1578;</em>':'All <em>Products</em>'):getCatLabel(cat);
  window.scrollTo({top:0,behavior:'smooth'});
}

function slideCard(pid,d){var p=products.find(function(x){return x.id===pid;});if(!p||p.images.length<=1)return;cardPos[pid]=((cardPos[pid]||0)+d+p.images.length)%p.images.length;updateSlider(pid);}
function dotCard(pid,i){cardPos[pid]=i;updateSlider(pid);}
function updateSlider(pid){
  var p=products.find(function(x){return x.id===pid;});if(!p)return;
  var idx=cardPos[pid]||0;
  var track=document.getElementById('trk-'+pid);
  if(track)track.style.transform=(lang==='ar'?'translateX(':'translateX(-')+(idx*100)+'%)';
  var dots=document.querySelectorAll('.cd-'+pid);
  for(var i=0;i<dots.length;i++)dots[i].classList.toggle('active',i===idx);
}

function renderProducts(){
  var grid=document.getElementById('products');
  var list=activeCategory==='&#1575;&#1604;&#1603;&#1604;'?products:products.filter(function(p){return p.category===activeCategory;});
  var cnt=document.getElementById('productCount');
  if(cnt)cnt.textContent=list.length+' '+(lang==='ar'?'&#1605;&#1606;&#1578;&#1580;':'products');
  if(list.length===0){grid.innerHTML='<div class="empty"><h3>'+t('noProducts')+'</h3><p>'+t('noProductsSub')+'</p></div>';return;}
  var h='';
  list.forEach(function(p){
    var v0=p.variants[0];
    var disc=v0.oldPrice?Math.round(100-(v0.price/v0.oldPrice*100)):0;
    cardPos[p.id]=0;
    var imgs=p.images.length>0?p.images:[PLACEHOLDER];
    var slides='';imgs.forEach(function(src){slides+='<img class="img-slide" src="'+src+'" alt="'+esc(p.name)+'" loading="lazy" onerror="this.src=PLACEHOLDER">';});
    var cdots='';if(imgs.length>1){imgs.forEach(function(s,i){cdots+='<div class="cdot cd-'+p.id+(i===0?' active':'')+'" onclick="event.stopPropagation();dotCard(\''+p.id+'\','+i+')"></div>';});}
    var arrows='';if(imgs.length>1){arrows='<button class="c-arrow cprev" onclick="event.stopPropagation();slideCard(\''+p.id+'\',-1)">&#8250;</button><button class="c-arrow cnext" onclick="event.stopPropagation();slideCard(\''+p.id+'\',1)">&#8249;</button>';}
    var badges='<div class="badge-row">';
    if(disc>0)badges+='<span class="badge badge-disc">'+t('discount')+' '+disc+'%</span>';
    if(p.isNew)badges+='<span class="badge badge-new">'+t('badgeNew')+'</span>';
    if(p.soldOut)badges+='<span class="badge badge-sold">'+t('badgeSold')+'</span>';
    badges+='</div>';
    var imgList='['+imgs.map(function(u){return'"'+u.replace(/"/g,'\\"')+'"';}).join(',')+']\n';
    var opts='';p.variants.forEach(function(v,i){opts+='<option value="'+i+'">'+esc(v.label)+' — '+v.price+' '+t('currency')+(v.oldPrice?' ('+t('was')+' '+v.oldPrice+')':'')+' </option>';});
    var sel=p.variants.length>1?'<select class="variant-select" id="sel-'+p.id+'" onchange="updPrice(\''+p.id+'\',this)" onclick="event.stopPropagation()">'+opts+'</select>':'';
    var addClick=p.variants.length>1?'addToCart(\''+p.id+'\',parseInt(document.getElementById(\'sel-'+p.id+'\').value))':'addToCart(\''+p.id+'\',0)';
    var btnCls=p.soldOut?'add-cart-btn btn-soldout':'add-cart-btn';
    var btnClick=p.soldOut?'':' onclick="event.stopPropagation();'+addClick+'"';
    var btnTxt=p.soldOut?t('soldOutBtn'):'&#128722; '+t('addToCart');
    h+='<div class="card reveal'+(p.soldOut?' sold-out-card':'')+'">' +
      '<div class="card-img" onclick="openLightbox('+imgList+',0)">' +
        '<div class="img-track" id="trk-'+p.id+'">'+slides+'</div>' +
        (imgs.length>1?'<div class="card-dots">'+cdots+'</div>':'')+arrows+badges+
      '</div>' +
      '<div class="card-body">' +
        '<span class="card-cat">'+esc(getCatLabel(p.category))+'</span>' +
        '<h3 class="card-title">'+esc(p.name)+'</h3>' +
        '<p class="card-desc">'+esc(p.desc)+'</p>'+sel+
        '<div class="price-row" id="pr-'+p.id+'"><span class="price-new">'+v0.price+' '+t('currency')+'</span>'+(v0.oldPrice?'<span class="price-old">'+v0.oldPrice+' '+t('currency')+'</span>':'')+
        '</div><button class="'+btnCls+'" id="add-'+p.id+'"'+btnClick+'>'+btnTxt+'</button>' +
      '</div></div>';
  });
  grid.innerHTML=h;
  initReveal();
}

function updPrice(pid,sel){
  var p=products.find(function(x){return x.id===pid;});
  var v=p.variants[parseInt(sel.value)];
  document.getElementById('pr-'+pid).innerHTML='<span class="price-new">'+v.price+' '+t('currency')+'</span>'+(v.oldPrice?'<span class="price-old">'+v.oldPrice+' '+t('currency')+'</span>':'');
}

var PLACEHOLDER='data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 600"%3E%3Crect width="600" height="600" fill="%23222"/%3E%3C/svg%3E';

loadProducts();
try{sb.channel('products-ch').on('postgres_changes',{event:'*',schema:'public',table:'products'},function(){loadProducts();}).subscribe();}catch(e){console.warn(e);}
</script>
</body>
