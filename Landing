    </div>
    <div class="step-item">
      <div class="step-circle"><span class="step-num">3</span><span class="step-icon">💝</span></div>
      <h3 class="step-title" id="step3Title">اطلبي واستمتعي</h3>
      <p class="step-desc" id="step3Desc">يتواصل معك فريقنا لتأكيد الطلب ويصلك في أسرع وقت</p>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features-section">
  <div class="feature-card"><div class="feature-icon">🌹</div><div class="feature-title" id="feat1T">عطور أصيلة</div><div class="feature-desc" id="feat1D">تشكيلة واسعة من العطور المحلية والعالمية</div></div>
