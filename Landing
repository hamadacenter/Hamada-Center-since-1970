function toggleLang(){lang=lang==='ar'?'en':'ar';applyLang();}

function initReveal(){
  var els=document.querySelectorAll('.stat-item,.step-item,.feature-card');
  if(!window.IntersectionObserver){els.forEach(function(e){e.classList.add('visible');});return;}
  var obs=new IntersectionObserver(function(entries){entries.forEach(function(en){if(en.isIntersecting)en.target.classList.add('visible');});},{threshold:.1});
  els.forEach(function(el){obs.observe(el);});
}
document.addEventListener('DOMContentLoaded',initReveal);
</script>
</body>
</html>
